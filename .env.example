# ========================================
# Backend Configuration
# ========================================

# LLM Provider: github (default) | groq
LLM_PROVIDER=github

# GitHub Models Configuration (free tier)
# Get a fine-grained token at https://github.com/settings/tokens
GITHUB_TOKEN=your_github_pat_here
GITHUB_MODEL=gpt-4o
GITHUB_TEMPERATURE=0.2

# Groq Configuration (fallback — set LLM_PROVIDER=groq to use)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TEMPERATURE=0.2

# Embedding Configuration
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# Chroma / uploads (paths relative to project root)
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=document_chunks
UPLOAD_DIR=./data/uploads

# ========================================
# Frontend Configuration
# ========================================
VITE_API_URL=http://localhost:8000

# ========================================
# FastAPI / CORS
# ========================================
# Comma-separated origins. Set CORS_ALLOW_ALL=true only for local debugging
# (browsers disallow credentials with wildcard origins).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# CORS_ALLOW_ALL=false

# ========================================
# Logging
# ========================================
LOG_LEVEL=INFO
